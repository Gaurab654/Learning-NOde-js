<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registered Homes</title>
    <!-- Tailwind CSS (via CDN for quick start; for production, install and build with PostCSS) -->
       <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    </head>

<body class="bg-gray-50 text-gray-900">

<!-- NAVBAR -->
<%- include('partials/navpartial') %>

<!-- MAIN -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- HEADER -->
    <header class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 md:gap-6 mb-6">
        <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Registered Homes</h1>
            <p class="text-sm text-gray-600">Simple list of all homes</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-md px-4 py-2 text-sm text-gray-700">
            Total: <span class="font-medium"><%= registeredHomes.length %></span>
        </div>
    </header>

    <!-- CONTENT -->
    <% if (registeredHomes.length > 0) { %>

        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% registeredHomes.forEach(home => { %>

                <article class="bg-white border border-gray-200 rounded-lg shadow-sm p-5 hover:shadow-md transition-shadow">
                    <h2 class="text-lg font-semibold text-gray-800 mb-2">
                        <%= home.houseName %>
                    </h2>

                    <p class="text-sm text-gray-600 mb-4">Available property</p>

                    <div class="flex items-center justify-between">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                            Available
                        </span>
                        <a href="#" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">View</a>
                    </div>
                </article>

            <% }) %>
        </section>

    <% } else { %>

        <section class="flex flex-col items-center justify-center py-12 bg-white border border-gray-200 rounded-lg">
            <h2 class="text-xl font-semibold text-gray-800 mb-2">No homes found</h2>
            <p class="text-sm text-gray-600 mb-4">Start by adding your first home</p>
            <a href="/host/add-home" class="px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-500">Add Home</a>
        </section>

    <% } %>

</main>

</body>
</html>
